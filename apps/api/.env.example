DATABASE_URL=postgresql://user:password@localhost:5432/fundy
JWT_SECRET=change-me-to-at-least-32-characters-long
JWT_REFRESH_SECRET=another-change-me-32-chars-minimum
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Tigris (S3-compatible)
TIGRIS_ACCESS_KEY_ID=
TIGRIS_SECRET_ACCESS_KEY=
TIGRIS_ENDPOINT=https://fly.storage.tigris.dev
TIGRIS_BUCKET=fundy-storage
TIGRIS_REGION=auto

# Email (optional — for invite/reset flows)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@fundy.app
